  "product_overview": "A comprehensive Django-based intelligent university timetable management system supporting multiple user roles for automated scheduling, room reservations, real-time notifications, and public access features, all presented in French with robust role-based content.",
  "core_goals": [
    "Automate university timetable generation and management with an intuitive web interface.",
    "Enable role-based access with tailored dashboards for administrators, teachers, students, associations, and guests.",
    "Facilitate room reservation requests with administrative approval and notifications.",
    "Provide real-time notifications for key events via WebSockets and Redis integration.",
    "Offer public access to landing pages, room searches, and registration forms without authentication.",
    "Ensure all user interactions and content are in French, adhering to local usability needs.",
    "Implement a scalable, maintainable OOP design with Django 5, Python 3.10+, and Bootstrap 5 for styling.",
    "Support bulk operations such as room creation and dynamic group loading based on program selection.",
    "Provide a responsive and user-friendly interface using Django Template Language and AJAX."
  ],
  "key_features": [
    "Role-based user authentication and session management supporting admin, teacher, student, association, and guest roles.",
    "Bulk room creation form with prefix and numeric range inputs enabling mass creation of rooms.",
    "Room reservation system allowing teachers and associations to request rooms with admin approval workflows.",
    "Real-time WebSocket-based notification system informing users of exam scheduling, reservation updates, timetable changes, and contact form messages.",
    "Student and association registration workflows with data validation and admin approval for associations.",
    "Contact form accessible to all users (including guests) with admin notification and response tracking.",
    "Weekly timetable views personalized for users by role, showing sessions and exams.",
    "Teacher unavailability management where teachers declare unavailable periods to avoid scheduling conflicts.",
    "Public landing page displaying system overview, stats, and access links without requiring login.",
    "Dynamic group selection in student registration based on selected program using AJAX.",
    "REST API endpoints for notifications allowing unread count and recent notifications retrieval and marking as read."
  ],
  "user_flow_summary": [
    "Guest accesses the public landing page with overview and navigation options to register or login.",
    "New users register as student or association; associations require admin approval before activation.",
    "Authenticated users login and land on role-specific dashboards.",
    "Teachers and associations submit room reservation requests specifying room, datetime, duration, reason, and exam flag.",
    "Admins review reservation requests, approve or reject, triggering notifications to requesters and affected students.",
    "Teachers declare unavailability periods through session management interfaces.",
    "Sessions (courses, TD, TP, exams) are created and linked to rooms, teachers, and groups with validation of conflicts.",
    "Users receive real-time notifications via WebSocket connection and see updates in notification dropdown and toast alerts.",
    "Users interact with the contact form to send messages; admins receive notifications and respond accordingly.",
    "Admins perform bulk room creation using range and prefix inputs to quickly add many rooms with common attributes."
  ],
  "validation_criteria": [
    "All user roles can successfully login and access their respective dashboards.",
    "Bulk room creation creates correct number of rooms with specified attributes and equipment.",
    "Room reservation requests validate room availability and submit successfully with correct requester type.",
    "Admin approval workflows for associations and reservations operate correctly, triggering notifications.",
    "Real-time WebSocket notifications are received instantly by users on relevant events.",
    "Public landing page loads correctly with accurate stats and accessible navigation.",
    "Registration forms dynamically update fields (e.g., groups by program) and validate input data.",
    "Contact form submissions successfully store in the database and notify administrators.",
    "Timetable views display accurate session information filtered by user role.",
    "Teacher unavailability periods are correctly stored and considered in scheduling conflicts.",
    "REST API endpoints for notifications respond with correct data and support marking as read.",
    "System UI content is entirely in French and styled consistently with Bootstrap 5."
  ],
